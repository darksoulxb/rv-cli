# Maintainer: darksoulxb <https://github.com/darksoulxb>

pkgname=rv-cli-git
pkgver=0.1.0.r0.ga1c5d9c
pkgrel=1
pkgdesc="A fast, no-bs command-line shortcut manager for the terminal (git)"
arch=('any')
url="https://github.com/darksoulxb/rv-cli"
license=('MIT')
depends=(
    'python>=3.10'
    'python-typer'
    'python-platformdirs'
    'python-rich'
    'python-click'
)
makedepends=(
    'git'
    'python-build'
    'python-installer'
    'python-wheel'
    'python-setuptools'
)
optdepends=(
    'bash: bash shell support'
    'zsh: zsh shell support'
    'fish: fish shell support'
)
provides=("rv-cli=$pkgver")
conflicts=('rv-cli')
source=("$pkgname::git+https://github.com/darksoulxb/rv-cli.git#branch=main")
b2sums=('SKIP')

pkgver() {
    cd "$pkgname"
    git describe --long --tags --abbrev=7 2>/dev/null \
        | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g' \
        || printf "%s.r%s.g%s" \
            "$(grep '^version' pyproject.toml | head -1 | cut -d'"' -f2)" \
            "$(git rev-list --count HEAD)" \
            "$(git rev-parse --short=7 HEAD)"
}

build() {
    cd "$pkgname"
    python -m build --wheel --no-isolation
}

check() {
    cd "$pkgname"
    python -c "from rv_cli.main import app; print('import OK')"
}

package() {
    cd "$pkgname"
    python -m installer --destdir="$pkgdir" dist/*.whl
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
